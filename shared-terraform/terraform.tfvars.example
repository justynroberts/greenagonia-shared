# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.

pagerduty_token  = "u+XXXXXXXXXXXXXXXXXXXX" # REST API key, admin/write scope
pagerduty_region = "us"                     # "eu" for *.eu.pagerduty.com accounts

# What "Mon-Fri 9-5" means for the admins' working-hours on-call layer.
schedule_time_zone = "Europe/London"

# Where the shared storefront is hosted — used to build per-admin links.
site_url = "http://localhost:8080"

# Incident Workflows are a paid feature; enable once entitlement confirmed.
enable_incident_workflows = false

# One entry per admin: initials → { name, email }.
# Email is their REAL PagerDuty notification address (they get the pages)
# and must not already exist as a user in the account.
admins = {
  JR = { name = "Justyn Roberts", email = "justyn@example.com" }
  # AB = { name = "Alice Bell",   email = "alice@example.com" }
}
